<?xml version="1.0" encoding="UTF-8"?>
<!--
    logback-spring.xml
    Place this file in: src/main/resources/

    Configures two appenders:
      1. CONSOLE  — coloured, human-readable output for development
      2. FILE     — rolling daily log file for persistent records

    Log levels:
      - com.mts.mts_purchase_service : INFO  (your app code)
      - org.springframework    : WARN  (suppress Spring's verbose startup noise)
      - org.hibernate.SQL      : INFO  (show SQL queries — set to WARN in prod)
      - root                   : WARN  (everything else stays quiet)
-->
<configuration>

    <!-- ── Properties ─────────────────────────────────────────── -->
    <property name="LOG_DIR"      value="logs" />
    <property name="LOG_FILE"     value="wholesale-grocery" />
    <property name="MAX_HISTORY"  value="30" />   <!-- keep 30 days of log files -->

    <!-- ── Console Appender ───────────────────────────────────── -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>
                %d{yyyy-MM-dd HH:mm:ss.SSS} %highlight(%-5level) %cyan([%thread]) %yellow(%logger{36}) - %msg%n
            </pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- ── Rolling File Appender ──────────────────────────────── -->
    <!--
        Creates one log file per day:
          logs/wholesale-grocery.log          (today, active file)
          logs/wholesale-grocery.2025-02-20.log  (yesterday, archived)
    -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/${LOG_FILE}.log</file>

        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <!-- Daily rollover -->
            <fileNamePattern>${LOG_DIR}/${LOG_FILE}.%d{yyyy-MM-dd}.log</fileNamePattern>
            <!-- Keep last 30 days -->
            <maxHistory>${MAX_HISTORY}</maxHistory>
            <!-- Cap total log folder size at 500MB -->
            <totalSizeCap>500MB</totalSizeCap>
        </rollingPolicy>

        <encoder>
            <pattern>
                %d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %logger{36} - %msg%n
            </pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- ── Your Application — INFO ────────────────────────────── -->
    <logger name="com.mts.mts_purchase_service" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE" />
        <appender-ref ref="FILE" />
    </logger>

    <!-- ── Hibernate SQL — INFO (shows queries in dev) ───────── -->
    <!-- Change to WARN in production to stop printing every SQL -->
    <logger name="org.hibernate.SQL"                         level="INFO"  additivity="false">
        <appender-ref ref="CONSOLE" />
    </logger>
    <logger name="org.hibernate.orm.jdbc.bind"               level="WARN" />
    <logger name="org.hibernate.type.descriptor.sql"         level="WARN" />

    <!-- ── Spring Framework — WARN (suppress startup noise) ──── -->
    <logger name="org.springframework"                        level="WARN" />
    <logger name="org.springframework.web"                    level="INFO" additivity="false">
        <appender-ref ref="CONSOLE" />
    </logger>

    <!-- ── Root logger — everything else ─────────────────────── -->
    <root level="WARN">
        <appender-ref ref="CONSOLE" />
        <appender-ref ref="FILE" />
    </root>

</configuration>
